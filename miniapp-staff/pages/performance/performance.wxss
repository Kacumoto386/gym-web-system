.stat-row {
  display: flex;
  justify-content: space-around;
  padding: 20rpx 0;
}
.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}
.stat-value {
  font-size: 40rpx;
  font-weight: 700;
}
.stat-label {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 8rpx;
}
.highlight { color: var(--brand-secondary); }
