<view class="page">
  <view class="card" wx:if="{{summary}}">
    <text class="section-title">{{year}}年{{month}}月 业绩概览</text>
    <view class="stat-row">
      <view class="stat-item">
        <text class="stat-value">¥{{summary.card_sales}}</text>
        <text class="stat-label">售卡</text>
      </view>
      <view class="stat-item">
        <text class="stat-value">¥{{summary.course_sales}}</text>
        <text class="stat-label">售课</text>
      </view>
      <view class="stat-item">
        <text class="stat-value highlight">¥{{summary.total}}</text>
        <text class="stat-label">总计</text>
      </view>
    </view>
  </view>
</view>
