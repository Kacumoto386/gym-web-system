.info-row {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 2rpx solid var(--border-color);
}
.info-label {
  color: var(--text-secondary);
  font-size: 26rpx;
}
.info-value {
  font-size: 28rpx;
  font-weight: 500;
}
.highlight {
  color: var(--brand-secondary);
  font-weight: 700;
}
.action-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.action-btn {
  flex: 1;
  min-width: 120rpx;
  background: var(--brand-bg);
  border: 2rpx solid var(--border-color);
  border-radius: 12rpx;
  padding: 20rpx;
  text-align: center;
  font-size: 26rpx;
}
.card-item {
  padding: 16rpx 0;
  border-bottom: 2rpx solid var(--border-color);
}
.card-name {
  font-size: 28rpx;
  font-weight: 500;
  display: block;
}
.card-info {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 6rpx;
}
