.search-card {
  padding: 20rpx;
}
.search-bar {
  display: flex;
  align-items: center;
  gap: 20rpx;
}
.search-input {
  flex: 1;
  border: 2rpx solid var(--border-color);
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
}
.search-btn {
  background: var(--brand-primary);
  color: #fff;
  border-radius: 12rpx;
  padding: 16rpx 36rpx;
  font-size: 28rpx;
  line-height: 1;
}
.member-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.member-name {
  font-size: 30rpx;
  font-weight: 500;
}
.member-phone {
  font-size: 26rpx;
  color: var(--text-secondary);
}
.member-lessons {
  font-size: 26rpx;
  color: var(--brand-secondary);
}
.empty {
  text-align: center;
  padding: 80rpx;
  color: var(--text-secondary);
  font-size: 28rpx;
}
