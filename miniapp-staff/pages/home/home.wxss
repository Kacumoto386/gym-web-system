.user-card {
  display: flex;
  flex-direction: column;
}
.greeting {
  font-size: 36rpx;
  font-weight: 600;
}
.today-label {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-top: 10rpx;
}
.search-card {
  padding: 20rpx;
}
.search-bar {
  display: flex;
  align-items: center;
  gap: 20rpx;
}
.search-input {
  flex: 1;
  border: 2rpx solid var(--border-color);
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
}
.search-btn {
  background: var(--brand-primary);
  color: #fff;
  border-radius: 12rpx;
  padding: 16rpx 36rpx;
  font-size: 28rpx;
  line-height: 1;
}
.section-title {
  font-size: 30rpx;
  font-weight: 600;
  display: block;
  margin-bottom: 24rpx;
}
.grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}
.grid-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
}
.grid-icon {
  font-size: 56rpx;
}
.grid-label {
  font-size: 24rpx;
  color: var(--text-primary);
  margin-top: 10rpx;
}
.version-bar { text-align: center; font-size: 22rpx; color: var(--text-secondary); padding: 40rpx 0 20rpx; }
