.product-item {
  padding: 24rpx;
  border: 2rpx solid var(--border-color);
  border-radius: 12rpx;
  margin-bottom: 16rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
}
.product-item.active {
  border-color: var(--brand-primary);
  background: #ebf4ff;
}
.product-name {
  font-size: 28rpx;
  font-weight: 500;
  flex: 1;
}
.product-price {
  font-size: 30rpx;
  color: var(--danger);
  font-weight: 600;
}
.product-info {
  width: 100%;
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 6rpx;
}
