.login-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 40rpx 0;
}
.logo-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
}
.logo-text {
  font-size: 120rpx;
}
.title {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--brand-primary);
  margin-top: 20rpx;
}
.subtitle {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-top: 10rpx;
}
.form-group {
  margin-bottom: 30rpx;
}
.login-page .card {
  width: 100%;
}
.login-page .btn-primary {
  margin-top: 40rpx;
  width: 100%;
}
