.stats-row { display: flex; justify-content: space-around; }
.stat-item { display: flex; flex-direction: column; align-items: center; }
.stat-value { font-size: 48rpx; font-weight: 700; color: var(--brand-primary); }
.stat-label { font-size: 24rpx; color: var(--text-secondary); }
.record-course { font-size: 28rpx; font-weight: 500; display: block; }
.record-coach { font-size: 24rpx; color: var(--text-secondary); margin-top: 6rpx; }
.load-more { text-align: center; padding: 30rpx; color: var(--brand-secondary); font-size: 26rpx; }
