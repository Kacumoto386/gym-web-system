.login-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 40rpx 0;
}
.logo-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
}
.logo-text { font-size: 120rpx; }
.title { font-size: 48rpx; font-weight: 700; color: var(--brand-primary); margin-top: 20rpx; }
.subtitle { font-size: 26rpx; color: var(--text-secondary); margin-top: 10rpx; }
.login-page .card { width: 100%; }
.login-page .btn-primary { margin-top: 20rpx; width: 100%; }
.divider { text-align: center; color: var(--text-secondary); margin: 30rpx 0; font-size: 26rpx; }
.btn-wechat {
  background: #07c160; color: #fff; border-radius: 12rpx;
  padding: 24rpx 48rpx; font-size: 30rpx; text-align: center; width: 100%;
}
.tips { display: block; text-align: center; color: var(--text-secondary); font-size: 24rpx; margin-top: 20rpx; }

/* Tab 切换栏 */
.tab-bar {
  display: flex;
  border-bottom: 2rpx solid #eee;
  margin-bottom: 30rpx;
}
.tab {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 30rpx;
  color: var(--text-secondary);
  position: relative;
}
.tab.active {
  color: var(--brand-primary);
  font-weight: 600;
}
.tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 20%;
  width: 60%;
  height: 4rpx;
  background: var(--brand-primary);
  border-radius: 2rpx;
}

/* 验证码行 */
.code-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}
.code-input {
  flex: 1;
}
.btn-code {
  flex-shrink: 0;
  font-size: 26rpx;
  background: var(--brand-primary);
  color: #fff;
  border-radius: 8rpx;
  padding: 18rpx 24rpx;
  line-height: 1.2;
  min-width: 180rpx;
  text-align: center;
}
.btn-code[disabled] {
  opacity: 0.6;
}

/* 切换方式链接 */
.link {
  display: block;
  text-align: right;
  color: var(--brand-primary);
  font-size: 26rpx;
  margin-top: 16rpx;
}
