<view class="page login-page">
  <view class="logo-area">
    <text class="logo-text">🏋️</text>
    <text class="title">会员中心</text>
    <text class="subtitle">随时随地 掌握健身动态</text>
  </view>

  <view class="card">
    <view class="tab-bar">
      <text class="tab {{tabIndex===0?'active':''}}" data-index="0" bindtap="switchTab">密码登录</text>
      <text class="tab {{tabIndex===1?'active':''}}" data-index="1" bindtap="switchTab">验证码登录</text>
    </view>

    <!-- 密码登录 -->
    <view wx:if="{{tabIndex===0}}">
      <view class="form-group">
        <text class="label">手机号</text>
        <input class="input-field" type="number" maxlength="11" placeholder="请输入手机号" value="{{phone}}" bindinput="onInputPhone" />
      </view>
      <view class="form-group">
        <text class="label">密码</text>
        <input class="input-field" password="{{true}}" placeholder="请输入密码" value="{{password}}" bindinput="onInputPassword" />
      </view>

      <button class="btn-primary" bindtap="onLoginByPassword" loading="{{loading}}" disabled="{{loading}}">
        {{loading ? '登录中...' : '登 录'}}
      </button>

      <text class="link" bindtap="switchToCodeTab">使用验证码登录 ›</text>
    </view>

    <!-- 验证码登录 -->
    <view wx:if="{{tabIndex===1}}">
      <view class="form-group">
        <text class="label">手机号</text>
        <input class="input-field" type="number" maxlength="11" placeholder="请输入手机号" value="{{phone}}" bindinput="onInputPhone" />
      </view>
      <view class="form-group">
        <text class="label">验证码</text>
        <view class="code-row">
          <input class="input-field code-input" type="number" maxlength="6" placeholder="输入验证码" value="{{code}}" bindinput="onInputCode" />
          <button class="btn-code" bindtap="onSendCode" disabled="{{codeSending || codeCountdown>0}}">
            {{codeCountdown > 0 ? codeCountdown+'s' : '获取验证码'}}
          </button>
        </view>
      </view>

      <button class="btn-primary" bindtap="onLoginByCode" loading="{{loading}}" disabled="{{loading}}">
        {{loading ? '登录中...' : '登 录'}}
      </button>

      <text class="link" bindtap="switchToPwdTab">使用密码登录 ›</text>
    </view>

    <view class="divider">或</view>

    <button class="btn-wechat" bindgetphonenumber="onGetPhoneNumber" open-type="getPhoneNumber">
      微信手机号一键登录
    </button>

    <text class="tips">首次登录将自动绑定会员账号</text>
  </view>
</view>
