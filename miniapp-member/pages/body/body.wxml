<view class="page">
  <view class="card" wx:if="{{latest}}">
    <text class="section-title">最近体测</text>
    <view class="body-grid">
      <view class="body-item"><text class="body-label">身高</text><text class="body-value">{{latest.height}}cm</text></view>
      <view class="body-item"><text class="body-label">体重</text><text class="body-value">{{latest.weight}}kg</text></view>
      <view class="body-item"><text class="body-label">体脂率</text><text class="body-value">{{latest.body_fat}}%</text></view>
    </view>
  </view>

  <view class="card">
    <text class="section-title">历史记录</text>
    <view wx:for="{{records}}" wx:key="id" class="body-history-row">
      <text>{{item.measure_date}}</text>
      <text>{{item.height}}cm / {{item.weight}}kg / {{item.body_fat}}%</text>
    </view>
    <view wx:if="{{records.length === 0}}" class="empty-text">暂无体测记录</view>
  </view>
</view>
