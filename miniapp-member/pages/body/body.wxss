.body-grid { display: flex; justify-content: space-around; }
.body-item { display: flex; flex-direction: column; align-items: center; }
.body-label { font-size: 24rpx; color: var(--text-secondary); }
.body-value { font-size: 36rpx; font-weight: 600; margin-top: 6rpx; }
.body-history-row { display: flex; justify-content: space-between; padding: 12rpx 0; font-size: 26rpx; border-bottom: 2rpx solid var(--border-color); }
.empty-text { text-align: center; color: var(--text-secondary); padding: 30rpx; }
