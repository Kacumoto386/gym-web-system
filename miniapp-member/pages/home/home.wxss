.profile-card { display: flex; flex-direction: column; align-items: center; }
.member-name { font-size: 40rpx; font-weight: 700; }
.member-phone { font-size: 26rpx; color: var(--text-secondary); margin-top: 8rpx; }
.stats-row { display: flex; justify-content: space-around; }
.stat-item { display: flex; flex-direction: column; align-items: center; }
.stat-value { font-size: 40rpx; font-weight: 700; }
.stat-label { font-size: 24rpx; color: var(--text-secondary); margin-top: 6rpx; }
.highlight { color: var(--brand-secondary); }
.grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20rpx; }
.grid-item { display: flex; flex-direction: column; align-items: center; padding: 20rpx 0; }
.grid-icon { font-size: 56rpx; }
.grid-label { font-size: 24rpx; margin-top: 10rpx; }
.alert-item { padding: 12rpx 0; font-size: 26rpx; color: var(--warning); }
.version-bar { text-align: center; font-size: 22rpx; color: var(--text-secondary); padding: 40rpx 0 20rpx; }
