.filter-bar { display: flex; background: #fff; margin: 20rpx; border-radius: 16rpx; overflow: hidden; }
.filter-item { flex: 1; text-align: center; padding: 20rpx 0; font-size: 26rpx; color: var(--text-secondary); }
.filter-item.active { color: var(--brand-primary); background: #ebf4ff; font-weight: 600; }

.order-card { display: flex; flex-direction: column; }
.order-header { display: flex; justify-content: space-between; align-items: center; }
.order-type { font-size: 26rpx; color: var(--brand-secondary); background: #ebf4ff; padding: 4rpx 14rpx; border-radius: 8rpx; }
.order-status { font-size: 26rpx; font-weight: 500; }
.order-status.pending { color: var(--warning); }
.order-status.completed { color: var(--success); }
.order-status.cancelled { color: var(--danger); }
.order-name { font-size: 30rpx; font-weight: 500; margin: 16rpx 0; }
.order-footer { display: flex; justify-content: space-between; align-items: center; border-top: 2rpx solid var(--border-color); padding-top: 14rpx; }
.order-amount { font-size: 32rpx; font-weight: 700; color: var(--danger); }
.order-time { font-size: 24rpx; color: var(--text-secondary); }
