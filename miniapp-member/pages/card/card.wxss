.card-item { display: flex; flex-direction: column; }
.card-header { display: flex; justify-content: space-between; align-items: center; }
.card-name { font-size: 30rpx; font-weight: 600; }
.card-type { font-size: 22rpx; color: var(--brand-secondary); background: #ebf4ff; padding: 6rpx 16rpx; border-radius: 8rpx; }
.card-body { display: flex; flex-direction: column; align-items: center; padding: 30rpx 0; }
.remain-count { font-size: 72rpx; font-weight: 700; color: var(--brand-primary); }
.remain-label { font-size: 24rpx; color: var(--text-secondary); }
.card-footer { display: flex; justify-content: space-between; border-top: 2rpx solid var(--border-color); padding-top: 16rpx; }
.card-date { font-size: 24rpx; color: var(--text-secondary); }
.card-status { font-size: 24rpx; }
.card-status.active { color: var(--success); }
